<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F5E9">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="40dp"
        android:paddingBottom="20dp">

        <!-- Logo Icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌿"
            android:textSize="72sp"
            android:layout_marginBottom="16dp"
            android:importantForAccessibility="no"/>

        <!-- PLANT SAVIOR PRO -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PLANT SAVIOR"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:textColor="#1B5E20"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" PRO"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="#43A047"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anlık Bitki Hastalığı Teşhisi"
            android:textSize="12sp"
            android:textColor="#66BB6A"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- KAYIT FORMU (Beyaz Kart) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/bg_rounded_top"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kayıt Ol"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="24dp"/>

        <!-- Ad Soyad -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ad Soyad"
            android:textSize="12sp"
            android:textColor="#555555"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/input_bg_pill"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_person"
                android:layout_marginEnd="10dp"/>

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="Adınız Soyadınız"
                android:inputType="textPersonName"
                android:background="@null"
                android:textSize="14sp"
                android:theme="@style/HintStyle"/>

        </LinearLayout>

        <!-- E-posta -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E-posta"
            android:textSize="12sp"
            android:textColor="#555555"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/input_bg_pill"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_email"
                android:layout_marginEnd="10dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="ornek@email.com"
                android:inputType="textEmailAddress"
                android:background="@null"
                android:textSize="14sp"
                android:theme="@style/HintStyle"/>

        </LinearLayout>

        <!-- Şifre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Şifre"
            android:textSize="12sp"
            android:textColor="#555555"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/input_bg_pill"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_lock"
                android:layout_marginEnd="10dp"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:background="@null"
                android:textSize="14sp"
                android:theme="@style/HintStyle"/>

        </LinearLayout>

        <!-- Şifre Tekrar -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Şifre Tekrar"
            android:textSize="12sp"
            android:textColor="#555555"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/input_bg_pill"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="28dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_lock"
                android:layout_marginEnd="10dp"/>

            <EditText
                android:id="@+id/etPasswordConfirm"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:background="@null"
                android:textSize="14sp"
                android:theme="@style/HintStyle"/>

        </LinearLayout>

        <!-- Kayıt Ol Butonu -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Kayıt Ol"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#43A047"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null"
            android:layout_marginBottom="16dp"/>


        <!-- Google ile Kayıt -->
        <LinearLayout
            android:id="@+id/btnGoogleRegister"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_google_bg"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_google"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Google ile Kayıt Ol"
                android:textSize="14sp"
                android:textColor="#333333"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Giriş Yap -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zaten hesabın var mı? "
                android:textSize="13sp"
                android:textColor="#888888"/>

            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giriş Yap"
                android:textSize="13sp"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>