<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F5E9">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="36dp"
        android:paddingBottom="20dp">

        <ImageView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_plant_logo"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Veridia"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:letterSpacing="0.05"/>



        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anlık Bitki Hastalığı Teşhisi"
            android:textSize="12sp"
            android:textColor="#66BB6A"
            android:layout_marginTop="3dp"/>

    </LinearLayout>

    <!-- BEYAZ KART -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_rounded_top"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Fotoğraf Alanı -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:id="@+id/layoutPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_photo_area">

                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@drawable/ic_plant_logo"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fotoğrafı buraya yükleyin"
                        android:textSize="14sp"
                        android:textColor="#AAAAAA"
                        android:layout_marginTop="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bitkinin yaprağını net çekin"
                        android:textSize="11sp"
                        android:textColor="#C8E6C9"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <ImageView
                    android:id="@+id/imgPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"/>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"/>

            </FrameLayout>

            <!-- Fotoğraf Çek & Galeriden Seç -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCamera"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="FOTOĞRAF ÇEK"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:backgroundTint="#43A047"
                    android:textColor="#FFFFFF"
                    app:icon="@drawable/ic_camera"
                    app:iconTint="#FFFFFF"
                    app:iconPadding="6dp"
                    app:iconGravity="textStart"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGallery"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="GALERİDEN SEÇ"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:backgroundTint="#F1F8E9"
                    android:textColor="#2E7D32"
                    app:icon="@drawable/ic_gallery"
                    app:iconTint="#2E7D32"
                    app:iconPadding="6dp"
                    app:iconGravity="textStart"
                    android:stateListAnimator="@null"
                    android:layout_marginStart="6dp"/>

            </LinearLayout>

            <!-- Analiz Et -->
            <Button
                android:id="@+id/btnAnalyze"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="ANALİZ ET"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#1B5E20"
                android:textColor="#FFFFFF"
                android:stateListAnimator="@null"
                android:visibility="gone"
                android:layout_marginBottom="14dp"/>

            <!-- İpucu Kartı -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_tip_card"
                android:padding="14dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_info"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="İpucu"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"
                        android:layout_marginBottom="3dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daha iyi sonuç için bitkinin hasta yapraklarını yakından, iyi ışıkta çekin."
                        android:textSize="12sp"
                        android:textColor="#555555"
                        android:lineSpacingMultiplier="1.4"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Gizli result view'lar -->
            <LinearLayout
                android:id="@+id/layoutResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView android:id="@+id/tvDiseaseName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView android:id="@+id/tvConfidence"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button android:id="@+id/btnAdvice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <!-- Ana Sayfa -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp">

                <View
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_nav_active"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_home"
                    android:importantForAccessibility="no"/>

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ana Sayfa"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Geçmiş -->
        <LinearLayout
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_history"
                android:importantForAccessibility="no"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Geçmiş"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Profil -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile"
                android:importantForAccessibility="no"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profil"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>