<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F5E9">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="36dp"
        android:paddingBottom="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:background="@drawable/bg_nav_active"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_back"
                android:importantForAccessibility="no"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Veridia"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:letterSpacing="0.05"/>



            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hastalık Tavsiyeleri"
                android:textSize="11sp"
                android:textColor="#66BB6A"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <View android:layout_width="36dp" android:layout_height="1dp"/>

    </LinearLayout>

    <!-- BEYAZ KART -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_rounded_top"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Başlık -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TAVSİYE EDİLEN ÖNLEMLER"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvAdviceDiseaseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvAdviceConfidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <!-- Kültürel Mücadele -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_tip_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:background="@drawable/bg_nav_active"
                        android:layout_marginEnd="10dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_plant_logo"
                            android:importantForAccessibility="no"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KÜLTÜREL MÜCADELE"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:letterSpacing="0.05"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvCultural"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:lineSpacingMultiplier="1.6"/>

            </LinearLayout>

            <!-- Biyolojik Mücadele -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_biological_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:background="@drawable/bg_biological_icon"
                        android:layout_marginEnd="10dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_info"
                            android:importantForAccessibility="no"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BİYOLOJİK MÜCADELE"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#1565C0"
                        android:letterSpacing="0.05"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvBiological"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:lineSpacingMultiplier="1.6"/>

            </LinearLayout>

            <!-- Kimyasal Mücadele -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_chemical_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:background="@drawable/bg_chemical_icon"
                        android:layout_marginEnd="10dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_info"
                            android:importantForAccessibility="no"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KİMYASAL MÜCADELE"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#B71C1C"
                        android:letterSpacing="0.05"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvChemical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:lineSpacingMultiplier="1.6"/>

            </LinearLayout>

            <!-- Uyarı -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_warning_card"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_info"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="2dp"
                    android:importantForAccessibility="no"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bu öneriler tavsiye niteliğindedir. Kesin tanı ve tedavi için bir ziraat mühendisine danışınız."
                    android:textSize="12sp"
                    android:textColor="#F57F17"
                    android:lineSpacingMultiplier="1.5"/>

            </LinearLayout>

            <!-- Ata Tohum Atfı -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#E8F5E9"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌾 Anadolu'nun binlerce yıllık tarım bilgeliği ile modern yapay zekanın buluşması. Ata tohumlarımızı, geleneksel tarım kültürümüzü ve çiftçimizin emeğini korumak için buradayız."
                    android:textSize="13sp"
                    android:textColor="#2E7D32"
                    android:lineSpacingMultiplier="1.5"
                    android:fontFamily="serif"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp">

                <View
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_nav_active"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_home"
                    android:importantForAccessibility="no"/>

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ana Sayfa"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_history"
                android:importantForAccessibility="no"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Geçmiş"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile"
                android:importantForAccessibility="no"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profil"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>